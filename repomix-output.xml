  content.style.display = 'block';
  noInvoice.style.display = 'none';

  const issuedDate = formatIssueDate(invoice.issued_at || invoice.issuedAt);
  const invoiceNumber = invoice.invoice_number || invoice.invoiceNumber || 'N/A';
  
