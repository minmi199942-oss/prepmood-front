            <div class="form-group">
              <label for="category" class="form-label">관심 분야 <span class="required">*</span></label>
              <select id="category" name="category" class="form-input" required>
                <option value="">선택해주세요</option>
                <option value="제품 관련 안내">I. 제품 관련 안내</option>
                <option value="구매 및 제공 가능 여부">II. 구매 및 제공 가능 여부</option>
