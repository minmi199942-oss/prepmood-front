// 결제수단 마스킹 처리
function maskPaymentMethod(method) {
  if (!method || method === '-') return '-';
  
  // 카드 번호 형식인 경우 마스킹
  if (/^\d{4}[\s-]?\d{4}[\s-]?\d{4}[\s-]?\d{4}$/.test(method.replace(/\s/g, ''))) {
    return method.replace(/(\d{4}[\s-]?)(\d{4}[\s-]?)(\d{4}[\s-]?)(\d{4})/, '$1****-****-$4');
  }
  
  // 일반 결제수단명은 그대로 표시
  return escapeHtml(method);
}

