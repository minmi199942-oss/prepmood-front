        'UPDATE cart_items SET size = ?, color = ?, quantity = ?, updated_at = NOW() WHERE item_id = ?',
        [size, color, quantity, itemId]
      );

      Logger.log(`장바구니 아이템 수정: 사용자${req.user.userId} - 아이템${itemId}`);

      res.json({ 
        success: true, 
