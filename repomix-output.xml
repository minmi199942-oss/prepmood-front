            word-break: break-word;
        }
        
        /* 점선 컷팅 라인 래퍼 */
        .ticket-divider-wrap {
            position: relative;
            margin: 22px -65px 18px -65px; /* card-content의 padding만큼 음수 마진으로 양쪽 끝까지 확장 */
            height: 3px; /* 점선 높이 */
            border-top: none; /* border 대신 background-image 사용 */
            background-image: repeating-linear-gradient(
                to right,
                #d0d0d0 0px,
                #d0d0d0 10px,  /* 점선 길이 */
                transparent 10px,
                transparent 20px  /* 점선 간격 (더 여유롭게) */
            );
            background-size: 30px 3px; /* 패턴 크기 */
            background-position: 0 0;
            background-repeat: repeat-x;
            overflow: visible;
        }
        
        /* ============================================
           좌측 노치 설정 (card-content 경계에 반씩 걸치도록)
           ============================================ */
        .ticket-divider-wrap::before {
            content: '';
            position: absolute;
            /* left: ticket-divider-wrap이 이미 margin -65px로 확장되어 있으므로,
               노치 지름의 절반만큼 음수로 설정하면 card-content 왼쪽 경계에 반씩 걸치게 됨 */
            left: calc(-28px / 2);
            
            /* top: 50% + transform = 점선 라인(높이 3px)의 정확한 중앙 높이에 배치 */
            top: 50%;
            transform: translateY(-50%);
            
            /* 노치 크기 */
            width: 28px;
            height: 28px;
            
            border-radius: 50%;
            
            /* 노치 색상: 소배경(stage-panel) 배경색과 동일하게 설정하면 카드가 파인 것처럼 보임 */
            background: #eeeeee;
            
            z-index: 10;
        }
        
        /* ============================================
           우측 노치 설정 (card-content 경계에 반씩 걸치도록)
           ============================================ */
        .ticket-divider-wrap::after {
            content: '';
            position: absolute;
            /* right: ticket-divider-wrap이 이미 margin -65px로 확장되어 있으므로,
               노치 지름의 절반만큼 음수로 설정하면 card-content 오른쪽 경계에 반씩 걸치게 됨 */
            right: calc(-28px / 2);
            
            /* top: 50% + transform = 점선 라인(높이 3px)의 정확한 중앙 높이에 배치 */
            top: 50%;
            transform: translateY(-50%);
            
            /* 노치 크기 */
            width: 28px;
            height: 28px;
            
            border-radius: 50%;
            
            /* 노치 색상: 소배경(stage-panel) 배경색과 동일하게 설정하면 카드가 파인 것처럼 보임 */
            background: #eeeeee;
            
            z-index: 10;
        }
        
        /* ============================================
           카드 컨테이너 설정 (반원 효과를 위한 overflow)
           ============================================
           overflow: hidden → 카드 밖의 노치 부분이 잘려서 반원처럼 보임
           overflow: visible → 노치 전체가 보임 (완전한 원)
           */
        .card-content {
            overflow: hidden;
        }
        
        /* 바코드 영역 */
        .barcode-section {
            text-align: center;
            margin: 32px 0;
        }
        
        .barcode-container {
            margin-bottom: 12px;
        }
        
        .barcode-container svg {
            max-width: 100%;
            height: auto;
        }
        
        .barcode-text {
            font-size: 14px;
            color: #666;
            letter-spacing: 1px;
            font-family: 'Courier New', monospace;
            font-weight: 500;
            margin-top: 8px;
            margin-bottom: -30px;
        }
        
        /* 정품 인증 완료 pill */
        .verified-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #1a1a1a;
            color: white;
            padding: 12px 20px;
            border-radius: 24px;
            font-size: 14px;
            font-weight: 500;
            margin: 24px auto;
            text-align: center;
            margin-top: -30px;
            margin-bottom: -30px;
        }
        
        .verified-pill .check-icon {
            width: 20px;
            height: 20px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .verified-pill .check-icon svg {
            width: 12px;
            height: 12px;
            stroke: #1a1a1a;
            stroke-width: 2.5;
        }
        
        /* 안내 문구 */
        .info-text {
            background: #f5f5f5;
            padding: 20px;
            border-radius: 8px;
            margin: 24px 0;
            text-align: left;
            font-family: 'NanumBarunGothic', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans KR', sans-serif;
        }
        
        .info-text p {
            font-size: 13px;
            color: #666;
            line-height: 1.8;
            margin-bottom: 8px;
            font-family: 'NanumBarunGothic', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans KR', sans-serif;
        }
        
        .info-text p:first-child {
            font-weight: 700;
        }
        
        .info-text p:last-child {
            margin-bottom: 0;
        }
        
        /* 하단 영역 (정품 인증 완료부터 버튼까지) - 이미 card-content-bottom에서 처리 */
        
        /* 버튼 영역 */
        .button-section {
            margin-top: 32px;
        }
        
        .btn {
            display: block;
            width: 100%;
            padding: 16px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 500;
            text-align: center;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 12px;
            border: none;
            font-family: inherit;
        }
        
        .btn:last-child {
            margin-bottom: 0;
        }
        
        .btn-primary {
            background: #1a1a1a;
            color: white;
        }
        
        .btn-primary:hover {
            background: #333;
        }
        
        .btn-secondary {
            background: white;
            color: #1a1a1a;
            border: 1px solid #ddd;
        }
        
        .btn-secondary:hover {
            background: #f9f9f9;
        }
        
        @media (max-width: 500px) {
            body {
                padding: 40px 16px;
            }
            
            .stage-panel {
                padding: 32px 20px;
            }
            
            .container {
                max-width: 100%;
                margin: 0;
            }
            
            .card-content {
                padding: 24px 20px;
            }
            
            .header-bar {
                padding: 40px 20px;
            }
            
            .brand-name {
                font-size: 28px;
                margin-left: 20px;
            }
            
            .header-date {
                margin-right: 20px;
            }
            
            .card-content-bottom {
                padding: 20px 20px 24px 20px;
                margin: 0;
            }
            
            .info-text {
                padding: 16px 20px;
                margin-left: -16px;
                margin-right: -16px;
                
                box-sizing: border-box;
            }
            
            .info-label {
                font-size: 11px;
                min-width: 80px;
            }
            
            .info-value {
                font-size: 13px;
            }
        }
        
        /* 310px 이하: 여백 축소 (더 구체적인 미디어 쿼리를 나중에 배치) */
        @media (max-width: 310px) {
            .header-bar {
                padding: 40px 10px !important;
            }
            
            .brand-name {
                font-size: 24px !important;
                margin-left: 10px !important;
            }
            
            .header-date {
                margin-right: 10px !important;
                font-size: 12px !important;
            }
        }
    </style>
</head>
