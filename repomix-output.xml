SELECT 
    status,
    COUNT(*) as count,
    ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM orders), 2) as percentage
FROM orders
GROUP BY status
ORDER BY count DESC;

-- ============================================================
-- 4. 체크 제약 위반 데이터 확인 (있으면 안 됨)
