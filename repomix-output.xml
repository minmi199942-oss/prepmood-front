                <input type="tel" id="phone" name="phone" placeholder="010-0000-0000">
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">완료</button>
        </form>

        <div class="skip-link">
            <a href="index.html">나중에 입력하기</a>
        </div>
    </div>

    <div id="footer-container"></div>

    <script src="utils.js" defer></script>
    <script src="header-loader.js"></script>
    <script src="header-scroll.js"></script>
    <script src="footer-loader.js"></script>
    <script>
        // 헤더 로드 후 검색 기능 완전히 숨기기
        function hideSearchFeatures() {
            const elementsToHide = [
                '#search-toggle',
                '#search-modal',
                '.search-modal',
                '.search-container',
                '.search-icon',
                '.search-input',
                '.search-results',
                '.search-modal-content'
            ];
            
            elementsToHide.forEach(selector => {
                const elements = document.querySelectorAll(selector);
                elements.forEach(el => {
                    if (el) {
                        el.style.display = 'none';
                        el.style.visibility = 'hidden';
                        el.style.opacity = '0';
                        el.style.pointerEvents = 'none';
                    }
                });
            });
        }
        
        // 헤더 로드 완료 후 실행
        setTimeout(hideSearchFeatures, 100);
        setTimeout(hideSearchFeatures, 300);
        setTimeout(hideSearchFeatures, 500);
        setTimeout(hideSearchFeatures, 1000);
        
        // DOM 변화 감지해서 계속 숨기기
        const observer = new MutationObserver(hideSearchFeatures);
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
    <script>
        // 로컬 개발 환경에서 실제 서버 API 사용 (로컬 DB 설정이 없을 경우)
        const API_BASE_URL = window.location.hostname === 'prepmood.kr' 
            ? window.location.origin 
            : 'https://prepmood.kr';

        // 로그인 상태 확인 (JWT 쿠키 기반)
        let user = null;
        let isLoggedIn = false;

        // 서버에서 사용자 정보 가져오기
        async function checkLoginStatus() {
            try {
                const response = await fetch(`${API_BASE_URL}/api/auth/me`, {
                    method: 'GET',
                    credentials: 'include'
                });

                if (response.ok) {
                    const data = await response.json();
                    if (data.success) {
                        user = data.user;
                        isLoggedIn = true;
                        Logger.log('로그인 상태 확인 성공:', user);
                    }
                }
            } catch (error) {
                Logger.log('로그인 상태 확인 실패:', error);
            }

            if (!isLoggedIn || !user) {
                alert('로그인이 필요합니다');
                window.location.href = 'login.html';
                return;
            }
        }

        // Google 정보 표시
        document.addEventListener('DOMContentLoaded', async function() {
            // 먼저 로그인 상태 확인
            await checkLoginStatus();
            
            const googleInfoDiv = document.getElementById('googleInfo');
            
            if (user.profilePicture) {
                googleInfoDiv.innerHTML = `
                    <img src="${user.profilePicture}" alt="프로필 이미지">
                    <div class="google-info-text">
                        <p><strong>${user.name || user.email}</strong></p>
                        <p class="email">${user.email}</p>
                    </div>
                `;
            } else {
                googleInfoDiv.innerHTML = `
                    <div class="google-info-text">
                        <p><strong>${user.name || user.email}</strong></p>
                        <p class="email">${user.email}</p>
                    </div>
                `;
            }

            // Google 이름 자동 입력
            if (user.name) {
                document.getElementById('name').value = user.name;
            }
        });

        // 폼 제출
        document.getElementById('completeProfileForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('submitBtn');
            const errorMessage = document.getElementById('errorMessage');

            submitBtn.disabled = true;
            submitBtn.textContent = '처리 중...';
            errorMessage.style.display = 'none';

            const formData = {
                name: document.getElementById('name').value.trim(),
                phone: document.getElementById('phone').value.trim()
            };

            try {
                Logger.log('API 호출 URL:', `${API_BASE_URL}/api/auth/complete-profile`);
                Logger.log('전송 데이터:', formData);

                const response = await fetch(`${API_BASE_URL}/api/auth/complete-profile`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include', // JWT 쿠키 포함
                    body: JSON.stringify(formData)
                });

                Logger.log('응답 상태:', response.status);

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('응답 오류:', errorText);
                    throw new Error(`서버 오류: ${response.status}`);
                }

                const data = await response.json();
                Logger.log('응답 데이터:', data);

                if (data.success) {
                    alert('추가 정보가 저장되었습니다!');
                    
                    // 메인으로 리디렉션 (JWT 쿠키는 이미 서버에서 업데이트됨)
                    window.location.href = 'index.html';
                } else {
                    throw new Error(data.error || '정보 저장에 실패했습니다.');
                }
            } catch (error) {
                console.error('추가 정보 저장 오류:', error);
                
                let errorMsg = '정보 저장 중 오류가 발생했습니다.';
                if (error.message.includes('Failed to fetch') || error.message.includes('ERR_CONNECTION_REFUSED')) {
                    errorMsg = '백엔드 서버에 연결할 수 없습니다. 서버가 실행 중인지 확인해주세요.';
                } else if (error.message) {
                    errorMsg = error.message;
                }
                
                errorMessage.textContent = errorMsg;
                errorMessage.style.display = 'block';
                
                submitBtn.disabled = false;
                submitBtn.textContent = '완료';
            }
        });
    </script>
</body>
</html>
