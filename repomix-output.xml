    <script>
        // 헤더 날짜 설정
        function setHeaderDate() {
            const dateElement = document.getElementById('header-date');
            const today = new Date();
            const year = today.getFullYear();
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const day = String(today.getDate()).padStart(2, '0');
            dateElement.textContent = `${year}-${month}-${day}`;
        }
        
        // 바코드 생성
        function generateBarcode() {
            const code = '{{ product.internal_code }}';
            if (code && typeof JsBarcode !== 'undefined') {
                try {
                    JsBarcode("#barcode", code, {
                        format: "CODE128",
                        width: 2,
                        height: 60,
                        displayValue: false,
                        margin: 10
                    });
                    
                    // 바코드 텍스트 표시
                    const barcodeText = document.getElementById('barcode-text');
                    barcodeText.textContent = `PREPMOOD_${code.replace(/\s/g, '_').toUpperCase()}`;
                } catch (error) {
                    console.error('바코드 생성 실패:', error);
                }
            }
        }
        
        // 페이지 로드 시 실행
        document.addEventListener('DOMContentLoaded', function() {
            setHeaderDate();
            generateBarcode();
        });
    </script>
