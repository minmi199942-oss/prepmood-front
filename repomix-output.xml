</head>
<body>
  <!-- 헤더는 header-loader.js에서 동적 로드 -->
  <div id="header-container"></div>

  <!-- 메인 컨텐츠 -->
  <main class="contact-main">
    <section class="ls-container ls-container--narrow">
      <div class="ls-container__inner">
        <div class="contact-container">
      
      <!-- 좌측: 안내 문구 섹션 -->
      <div class="contact-info-section">
        <h1 class="contact-title">문의 접수</h1>
        <p class="contact-description">
          아래 정보를 남겨주시면 전담 컨시어지를 통해 순차적으로 안내드릴 예정입니다.
        </p>
        <p class="contact-required-note">* 필수 항목</p>
      </div>

      <!-- 우측: 폼 섹션 -->
      <div class="contact-form-section">
        <form id="inquiryForm" class="inquiry-form">
          
          <!-- 고객 정보 -->
          <div class="form-section">
            <h2 class="form-section-title">고객 정보</h2>
            
            <div class="form-group">
              <label for="salutation" class="form-label">호칭 <span class="required">*</span></label>
              <select id="salutation" name="salutation" class="form-input" required>
                <option value="">선택해주세요</option>
                <option value="남성">남성</option>
                <option value="여성">여성</option>
              </select>
            </div>

            <div class="form-group">
              <label for="name" class="form-label">이름 <span class="required">*</span></label>
              <input type="text" id="name" name="name" class="form-input" required maxlength="100">
            </div>

            <div class="form-group">
              <label for="email" class="form-label">이메일 <span class="required">*</span></label>
              <input type="email" id="email" name="email" class="form-input" required>
            </div>

            <div class="form-group">
              <label for="region" class="form-label">선호 지역 <span class="required">*</span></label>
              <select id="region" name="region" class="form-input" required>
                <option value="">선택해주세요</option>
                <option value="한국">한국</option>
                <option value="일본">일본</option>
                <option value="미국">미국</option>
                <option value="중국">중국</option>
                <option value="영국">영국</option>
                <option value="독일">독일</option>
                <option value="기타">기타</option>
              </select>
            </div>

            <div class="form-group">
              <label for="city" class="form-label">도시</label>
              <input type="text" id="city" name="city" class="form-input" maxlength="80">
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="countryCode" class="form-label">국가 코드 <span class="required">*</span></label>
                <select id="countryCode" name="country_code" class="form-input" required>
                  <option value="">선택</option>
                  <option value="+82">+82 (한국)</option>
                  <option value="+81">+81 (일본)</option>
                  <option value="+1">+1 (미국/캐나다)</option>
                  <option value="+86">+86 (중국)</option>
                  <option value="+44">+44 (영국)</option>
                  <option value="+49">+49 (독일)</option>
                </select>
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">전화번호 <span class="required">*</span></label>
                <input type="text" id="phone" name="phone" class="form-input" required maxlength="30">
              </div>
            </div>
          </div>

          <!-- 문의 사항 -->
          <div class="form-section">
