-- CREATE INDEX idx_product_name ON warranties(product_name);

-- 정책 준수 확인:
-- ✅ public_id: UUID 형식, UNIQUE 제약, NOT NULL, 외부 노출 가능
-- ✅ product_name: 발급 시점 스냅샷 저장 (비정규화, 성능 우선)
-- ✅ 기존 데이터 백필: UUID()로 자동 생성 (안전한 순서)
-- ✅ 인덱스: public_id UNIQUE 인덱스로 조회 최적화
